<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

<div class="admin-shell">
  <header class="admin-header">
    <span class="admin-logo">✦ ASTRAL — Administration</span>
    <form method="POST" action="/admin/logout">
      <button type="submit" class="admin-logout">Déconnexion</button>
    </form>
  </header>

  <div class="admin-stats-row">
    <div class="admin-stat-card">
      <span class="admin-stat-num"><%= stats.totalBookings %></span>
      <span class="admin-stat-label">Réservations totales</span>
    </div>
    <div class="admin-stat-card">
      <span class="admin-stat-num"><%= stats.enAttente %></span>
      <span class="admin-stat-label">En attente</span>
    </div>
    <div class="admin-stat-card">
      <span class="admin-stat-num"><%= stats.confirmees %></span>
      <span class="admin-stat-label">Confirmées</span>
    </div>
    <div class="admin-stat-card">
      <span class="admin-stat-num"><%= stats.revenue.toLocaleString('fr-FR') %> FCFA</span>
      <span class="admin-stat-label">Revenu cumulé (estimé)</span>
    </div>
  </div>

  <section class="admin-section">
    <div class="admin-section-header">
      <h2>Réservations</h2>
      <form class="admin-filters" method="GET">
        <input type="text" name="recherche" placeholder="Rechercher (nom, email, n° réservation...)" value="<%= recherche %>">
        <select name="statut">
          <option value="">Tous les statuts</option>
          <option value="en_attente" <%= statutFilter === 'en_attente' ? 'selected' : '' %>>En attente</option>
          <option value="confirmée" <%= statutFilter === 'confirmée' ? 'selected' : '' %>>Confirmée</option>
          <option value="annulée" <%= statutFilter === 'annulée' ? 'selected' : '' %>>Annulée</option>
        </select>
        <button type="submit" class="btn-room">Filtrer</button>
      </form>
    </div>

    <table class="admin-table">
      <thead>
        <tr>
          <th>Référence</th>
          <th>Client</th>
          <th>Chambre</th>
          <th>Dates</th>
          <th>Total</th>
          <th>Statut</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (bookings.length === 0) { %>
          <tr><td colspan="7" class="admin-empty">Aucune réservation pour le moment.</td></tr>
        <% } %>
        <% bookings.forEach(b => { %>
          <tr>
            <td><strong><%= b.ref %></strong></td>
            <td><%= b.client.prenom %> <%= b.client.nom %><br><small><%= b.client.email %></small></td>
            <td><%= b.roomName %></td>
            <td><%= new Date(b.arrivee).toLocaleDateString('fr-FR') %> → <%= new Date(b.depart).toLocaleDateString('fr-FR') %></td>
            <td><%= b.total.toLocaleString('fr-FR') %> FCFA</td>
            <td><span class="status-badge status-badge--<%= b.status %>"><%= b.status %></span></td>
            <td>
              <form method="POST" action="/admin/booking/<%= b.ref %>/status" class="admin-status-form">
                <select name="status" onchange="this.form.submit()">
                  <option value="en_attente" <%= b.status === 'en_attente' ? 'selected' : '' %>>En attente</option>
                  <option value="confirmée" <%= b.status === 'confirmée' ? 'selected' : '' %>>Confirmée</option>
                  <option value="annulée" <%= b.status === 'annulée' ? 'selected' : '' %>>Annulée</option>
                </select>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>

  <section class="admin-section">
    <h2>Demandes de devis (Réunion / Sport)</h2>
    <table class="admin-table">
      <thead>
        <tr><th>Type</th><th>Nom</th><th>Contact</th><th>Date souhaitée</th><th>Détails</th></tr>
      </thead>
      <tbody>
        <% if (quoteRequests.length === 0) { %>
          <tr><td colspan="5" class="admin-empty">Aucune demande de devis pour le moment.</td></tr>
        <% } %>
        <% quoteRequests.forEach(q => { %>
          <tr>
            <td><%= q.type === 'reunion' ? 'Salle de réunion' : 'Salle de sport' %></td>
            <td><%= q.nom %></td>
            <td><%= q.email %><br><small><%= q.telephone %></small></td>
            <td><%= q.dateSouhaitee || '—' %></td>
            <td><%= q.details || '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>

  <section class="admin-section">
    <h2>Messages de contact</h2>
    <table class="admin-table">
      <thead>
        <tr><th>Nom</th><th>Contact</th><th>Message</th></tr>
      </thead>
      <tbody>
        <% if (contactMessages.length === 0) { %>
          <tr><td colspan="3" class="admin-empty">Aucun message pour le moment.</td></tr>
        <% } %>
        <% contactMessages.forEach(m => { %>
          <tr>
            <td><%= m.nom %></td>
            <td><%= m.email %><br><small><%= m.telephone %></small></td>
            <td><%= m.message %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
</div>

</body>
</html>
